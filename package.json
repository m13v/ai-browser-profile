    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "framer-motion": "^12.38.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.446",
