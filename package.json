  "bin": {
    "ai-browser-profile": "bin/cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "bin/",
    "ai_browser_profile/**/*.py",
    "skill/",
    "review/",
    "setup/",
    "autofill/",
    "whatsapp/",
    "extract.py",
    "clean.py"
  ],
  "keywords": [
    "browser-data",
    "browser-profile",
    "identity",
    "claude",
    "claude-code",
    "ai-agent",
    "knowledge-base",
